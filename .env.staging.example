# ============================================================================
# ARIA CLINIC — STAGING ENVIRONMENT CONFIGURATION
# ============================================================================
# THIS FILE IS A TEMPLATE
# DO NOT commit real credentials to git
# Use this as a guide to create .env.staging in your local environment
#
# Instructions:
# 1. Copy this file to .env.staging (NOT committed)
# 2. Replace placeholder values with real staging credentials
# 3. Source before running: source .env.staging
# 4. Keep .env.staging in .gitignore
#
# Credentials come from Supabase Staging Project:
# https://app.supabase.com → Project Settings → API
# ============================================================================

# ============================================================================
# SUPABASE STAGING CONFIGURATION
# ============================================================================

# Project URL (from Supabase dashboard → Project Settings → API)
# Format: https://[PROJECT-REF].supabase.co
# Do NOT include /rest/v1 or trailing slashes
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-STAGING-PROJECT-REF].supabase.co

# Anonymous Key (from Supabase dashboard → Project Settings → API)
# This is the public anon key, safe to expose in browser
# Starts with "eyJhbGc..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IltQUk9KRUNULVJFRF0iLCJyb2xlIjoiYW5vbiIsImlhdCI6WUVBUiwiZXhwIjo4NzM0NjQwMDB9.[HASH]

# Service Role Key (from Supabase dashboard → Project Settings → API)
# SENSITIVE: Only use server-side (never expose to client)
# For server-side operations: /api/* routes, backend jobs
# Starts with "eyJhbGc..."
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IltQUk9KRUNULVJFRF0iLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjpZRUFSLCJleHAiOjg3MzQ2NDAwMH0.[HASH]

# Database connection details (optional, for direct DB access)
# URL format: postgresql://[user]:[password]@[host]:[port]/[database]
# SENSITIVE: Use only for migrations and admin tasks
SUPABASE_DB_URL=postgresql://postgres:[DB-PASSWORD]@[PROJECT-REF].db.supabase.co:5432/postgres

# Database password from project creation (Step 1.2)
# Used by: CLI migrations, direct DB connections
SUPABASE_DB_PASSWORD=[YOUR-DATABASE-PASSWORD]

# Project reference (used by CLI and automation)
# Format: [PROJECT-REF] (without full URL)
# Example: abcdefghijklmno (14 characters)
SUPABASE_PROJECT_REF=[YOUR-STAGING-PROJECT-REF]

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment stage
NODE_ENV=production

# Application name (for branding, logging)
NEXT_PUBLIC_APP_NAME=aria-clinic-staging

# Application version (for tracking deployments)
NEXT_PUBLIC_APP_VERSION=0.1.0-staging

# Enable debug logging (set to "false" in production)
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# DEPLOYMENT CONFIGURATION (Vercel / Hosting)
# ============================================================================

# Vercel deployment URL (auto-generated, or custom domain)
# Format: https://[app-name].vercel.app OR custom domain
# Will be populated automatically if deploying to Vercel
VERCEL_URL=https://aria-clinic-staging.vercel.app

# Disable Next.js telemetry for privacy
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================

# Email service (for notifications)
# Example: sendgrid, resend, mailgun
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# SMS service (for WhatsApp / SMS reminders)
# Example: twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Third-party APIs
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: MONITORING & LOGGING
# ============================================================================

# Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o123456.ingest.sentry.io/123456

# PostHog analytics (privacy-friendly)
# NEXT_PUBLIC_POSTHOG_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LogRocket session replay
# NEXT_PUBLIC_LOGROCKET_ID=xxxxxxxx/xxxxxxxx

# ============================================================================
# NOTES FOR DEVELOPERS
# ============================================================================

# LOCAL DEVELOPMENT WORKFLOW:
# 1. Create .env.staging in project root (not committed)
# 2. source .env.staging
# 3. npm run dev
# 4. App will use staging credentials instead of production

# VERCEL DEPLOYMENT:
# GitHub Actions workflow automatically handles environment variables
# Secrets are configured in GitHub: Settings → Secrets and variables

# PRODUCTION CREDENTIALS:
# Use different .env.production with production Supabase project
# Keep separate, never mix staging/production credentials

# ROTATING CREDENTIALS:
# When rotating keys in Supabase:
# 1. Generate new key in Supabase dashboard
# 2. Update this file
# 3. Update GitHub Secrets
# 4. Redeploy application
# 5. Old keys remain functional for 24-48 hours (grace period)

# TROUBLESHOOTING:
# If environment variables not loading:
# - Verify .env.staging is in project root (not in subdirectory)
# - Check that .gitignore includes .env.staging
# - Restart dev server: npm run dev
# - Verify no syntax errors in this file

# ============================================================================
# TEMPLATE COMPLETION CHECKLIST
# ============================================================================

# Before using this file:
# [ ] Replace [YOUR-STAGING-PROJECT-REF] with real Supabase project ref
# [ ] Replace [YOUR-DATABASE-PASSWORD] with database password
# [ ] Replace all eyJhbGc... placeholder keys with real keys
# [ ] Set NODE_ENV=production (for staging staging)
# [ ] Test with: npm run dev
# [ ] Verify app loads without authentication errors
# [ ] Rename file from .env.staging.example to .env.staging (local only)

# ============================================================================
# REFERENCE: GETTING CREDENTIALS
# ============================================================================

# Supabase Project Reference:
# 1. Go to https://app.supabase.com
# 2. Select your staging project
# 3. Click "Project Settings" (gear icon)
# 4. Click "General" tab
# 5. Copy "Reference ID"

# API Keys:
# 1. In "Project Settings", click "API" tab
# 2. Copy "Project URL" (remove /rest/v1 if present)
# 3. Copy "anon public key"
# 4. Copy "service_role key"

# Database Password:
# 1. In "Project Settings", click "Database" tab
# 2. Or use password created during project setup
# 3. Reset if forgotten: Project Settings → Database → Reset password

# ============================================================================
